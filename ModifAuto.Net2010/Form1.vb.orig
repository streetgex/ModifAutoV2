Imports System.DirectoryServices
Imports System.IO
Imports System.Net.Mail

Public Class Form1
    Shared persoFTP As FTPP = New FTPP()
    Shared tabPerso1 As String(,)
    Shared journalECHECMail As String = ""
    Shared controlSendMail As Boolean = False
    Declare Sub Sleep Lib "kernel32" (ByVal dwMilliseconds As Integer)

    Shared Sub exec(ByVal cmd As String, Optional ByVal argu As String = "")
        Dim p As New Process
        p.StartInfo.UseShellExecute = False
        p.StartInfo.CreateNoWindow = True

        p.StartInfo.Arguments = argu
        p.StartInfo.FileName = cmd
        p.Start()
        p.WaitForExit(5000)
    End Sub
    Shared Sub Main()

        Journal("Debut de traitement")

        Dim tableauE As String(,)
        Dim champE As String()
        Dim ligneE As String
        Dim j As Integer
        Dim addeqimpr

        ' RECUPERATION FICHIERS PAR FTP

        Dim server As String = ""
        Dim account As String = ""
        Dim psswdtmp As String = ""
        Dim psswd As String = ""
        Dim repd As String = ""

        Dim monStreamReader As StreamReader = New StreamReader("\\igbmc.u-strasbg.fr\SYSVOL\igbmc.u-strasbg.fr\Scripts\ScriptSteph.ini")
        Dim ligne As String
        Do
            ligne = monStreamReader.ReadLine()
            If ligne = "[FCCserver]" Then
                server = monStreamReader.ReadLine()
            End If
            If ligne = "[FCCFilePath]" Then
                repd = monStreamReader.ReadLine()
            End If
            If ligne = "[FCCAccount]" Then
                account = monStreamReader.ReadLine()
            End If
            If ligne = "[FCCPassword]" Then
                Do
                    psswdtmp = monStreamReader.ReadLine()
                    Dim rep As String = Chr(98) & Chr(72) & Chr(113) 'bHq

                    Dim pos As Integer = Strings.InStr(psswdtmp, rep)
                    If pos <> 0 Then
                        psswd = psswd & Strings.Mid(psswdtmp, pos + 3, 1)
                    End If

                Loop Until psswdtmp = "-----END RSA PRIVATE KEY-----"
            End If
        Loop Until ligne Is Nothing

        monStreamReader.Close()
        monStreamReader = Nothing

        persoFTP.m_FTPSite = "ftp://" & server
        persoFTP.UserName = account
        persoFTP.Password = psswd

        persoFTP.GetFile("/" & repd & "/eq.txt", "c:\temp\eq.txt")
        persoFTP.GetFile("/" & repd & "/listepersonew.txt", "c:\temp\listepers.txt")


        'SUPPRESSION DES ACCENTS DANS LE FICHIER DU PERSONNEL
        Dim Tc As String()
        FileOpen(2, "c:\temp\listep1.txt", OpenMode.Output) 'fichier du personnel sans accent multi equipe
        FileOpen(3, "c:\temp\listepers.txt", OpenMode.Input)

        Dim h As Integer = -1

        While Not EOF(3)
            h = h + 1
            ReDim Preserve Tc(h)
            Tc(h) = LineInput(3)
            Tc(h) = Replace(Tc(h), "â", "a")
            Tc(h) = Replace(Tc(h), "à", "a")
            Tc(h) = Replace(Tc(h), "é", "e")
            Tc(h) = Replace(Tc(h), "É", "E")
            Tc(h) = Replace(Tc(h), "È", "E")
            Tc(h) = Replace(Tc(h), "è", "e")
            Tc(h) = Replace(Tc(h), "ê", "e")
            Tc(h) = Replace(Tc(h), "ë", "e")
            Tc(h) = Replace(Tc(h), "ì", "i")
            Tc(h) = Replace(Tc(h), "î", "i")
            Tc(h) = Replace(Tc(h), "ï", "i")
            Tc(h) = Replace(Tc(h), "ü", "u")
            Tc(h) = Replace(Tc(h), "ù", "u")
            Tc(h) = Replace(Tc(h), "ö", "o")
            Tc(h) = Replace(Tc(h), "ô", "o")
            Tc(h) = Replace(Tc(h), "ç", "c")
            PrintLine(2, Tc(h))

        End While
        FileClose(2)
        FileClose(3)

        'DETERMINER L'EQUIPE PRINCIPALE
        FileOpen(1, "c:\temp\listep1.txt", OpenMode.Input) 'fichier du personnel sans accent multi equipe
        Dim ligneP As String
        Dim lignePerso As String()

        Dim g As Integer = 0
        While Not EOF(1)

            ligneP = LineInput(1)
            ReDim Preserve tabPerso1(10, g)
            lignePerso = Split(ligneP, ",")
            tabPerso1(0, g) = lignePerso(0)
            tabPerso1(1, g) = lignePerso(1)
            tabPerso1(2, g) = lignePerso(2)
            tabPerso1(3, g) = lignePerso(3)
            tabPerso1(4, g) = lignePerso(4)
            tabPerso1(5, g) = lignePerso(5)
            tabPerso1(6, g) = lignePerso(6)
            tabPerso1(7, g) = lignePerso(7)
            tabPerso1(8, g) = lignePerso(8)
            tabPerso1(9, g) = lignePerso(9)
            tabPerso1(10, g) = lignePerso(10)


            If g <> 0 Then
                If tabPerso1(2, g) = tabPerso1(2, g - 1) Then
                    If tabPerso1(5, g) > tabPerso1(5, g - 1) Then
                        tabPerso1(0, g - 1) = tabPerso1(0, g)
                        tabPerso1(1, g - 1) = tabPerso1(1, g)
                        tabPerso1(2, g - 1) = tabPerso1(2, g)
                        tabPerso1(3, g - 1) = tabPerso1(3, g)
                        tabPerso1(4, g - 1) = tabPerso1(4, g)
                        tabPerso1(5, g - 1) = tabPerso1(5, g)
                        g = g - 1
                    Else
                        g = g - 1
                    End If
                End If
            End If
            g = g + 1
        End While

        FileClose(1)


        FileOpen(1, "c:\temp\listep.txt", OpenMode.Output) 'fichier du personnel sans accent mono equipe

        For i = 0 To g - 1
            tabPerso1(6, i) = Replace(tabPerso1(6, i), "BATIMENT ICS", "ICS")
            tabPerso1(6, i) = Replace(tabPerso1(6, i), "C.E.B.G.S", "CEBGS")
            tabPerso1(6, i) = Replace(tabPerso1(6, i), "E.S.B.S.", "ESBS")

            If Len(tabPerso1(7, i)) = 4 And tabPerso1(7, i) <> "----" Then
                tabPerso1(7, i) = "(+3338865) " & tabPerso1(7, i)
            End If
            PrintLine(1, tabPerso1(0, i) & "," & tabPerso1(1, i) & "," & tabPerso1(2, i) & "," & tabPerso1(3, i) & "," & tabPerso1(4, i) & "," & tabPerso1(5, i) & "," & tabPerso1(6, i) & "," & tabPerso1(7, i) & "," & tabPerso1(8, i) & "," & tabPerso1(9, i))
        Next i
        FileClose(1)


        'CREATION DE LA LISTE DES EQUIPES
        FileOpen(1, "c:\temp\listepers.txt", OpenMode.Input)
        FileOpen(2, "c:\temp\eq.txt", OpenMode.Output)
        j = 0
        While Not EOF(1)
            Dim ctrl As Integer = 0
            ligneE = LineInput(1)
            champE = Split(ligneE, ",")
            For i = 0 To j
                ReDim Preserve tableauE(2, j)
                If champE(3) = tableauE(0, i) Then
                    GoTo sortie1
                Else
                    If ctrl = j Then
                        tableauE(0, j) = champE(3)
                        tableauE(1, j) = champE(4)
                        'chef d'equipe comptable
                        tableauE(2, j) = champE(9)
                        PrintLine(2, champE(3) & "," & champE(4) & "," & champE(9))
                        j = j + 1

                    End If
                    ctrl = ctrl + 1
sortie1:
                End If
            Next i
        End While

        FileClose(1)
        FileClose(2)


        'COMPARAISON DES EQUIPES ENTRE HIER ET AUJOURDH'HUI
        Dim tableauA() As String


        FileOpen(1, "c:\temp\eq.txt", OpenMode.Input)

        'creation du fichier eq.txt
        Dim m As Integer = -1
        While Not EOF(1)
            m = m + 1
            ReDim Preserve tableauA(m)
            tableauA(m) = LineInput(1)
        End While

        FileClose(1)
        Dim tableauB As String() = tableauA.Clone

        'AJOUT DES NOUVELLES EQUIPES

        Dim temp() As String
        Dim objDomGroup As DirectoryEntry = New DirectoryEntry("LDAP://OU=Equipes,DC=igbmc,DC=u-strasbg,DC=fr")
        Dim dirSearcher As DirectorySearcher = New DirectorySearcher(objDomGroup)


        For l = 0 To UBound(tableauA)
            If tableauA(l) <> "" Then
                temp = Split(tableauA(l), ",")



                dirSearcher.Filter = "(&(objectClass=group) (SAMAccountName=" & temp(0) & " grp" & "))"
                dirSearcher.SearchScope = SearchScope.OneLevel
                Dim result As SearchResult = dirSearcher.FindOne()
                If result Is Nothing Then
                    Dim nouveauGroupe As DirectoryEntries = objDomGroup.Children
                    Dim newgroup As DirectoryEntry = nouveauGroupe.Add("CN=" & temp(0) & " grp", "group")
                    newgroup.Properties("SAMAccountName").Add(temp(0) & " grp")
                    newgroup.Properties("description").Add(temp(1))
                    If temp(2) <> "?" Then
                        newgroup.Properties("managedBy").Value = TransformeSAMACCOUNTenCN(temp(2))
                    End If
                    newgroup.CommitChanges()
                    newgroup.Close()
                    newgroup = Nothing

                    addeqimpr = "PASCmd serv-impr.igbmc.u-strasbg.fr dp """ & temp(0) & """ add ""0"" """ & temp(1) & """ """" ""0"" "
                    Shell(addeqimpr, AppWinStyle.Hide)
                Else
                    tableauA(l) = ""
                    If temp(2) <> "?" Then
                        Dim CNchefEquipe As String = TransformeSAMACCOUNTenCN(temp(2))
                        Dim DirEntry As New DirectoryEntry(result.Path)

                        If DirEntry.Properties("managedBy").Value <> CNchefEquipe Then
                            DirEntry.Properties("managedBy").Value = CNchefEquipe
                            DirEntry.CommitChanges()
                        End If
                        DirEntry = Nothing
                    End If
                End If


                result = Nothing
            End If

        Next l

        'Nettoyage des equipes comptables
        dirSearcher.Filter = "(&(objectClass=group))"
        dirSearcher.SearchScope = SearchScope.OneLevel
        dirSearcher.PropertiesToLoad.Add("SAMAccountName")
        Dim result1 As SearchResultCollection = dirSearcher.FindAll

        For Each grpResult In result1
            Dim ctrlGrp As Boolean = False
            Dim nomGroup As String = grpResult.Properties("SAMAccountName")(0)
            For l = 0 To UBound(tableauB)

                If nomGroup = Split(tableauB(l), ",")(0) & " grp" Then
                    ctrlGrp = True
                    Exit For
                End If
            Next
            If ctrlGrp = False Then
                Dim objADAM As Object = GetObject(objDomGroup.Path)
                objADAM.Delete("group", "CN=" & nomGroup)
                objADAM = Nothing
            End If
        Next
        result1 = Nothing
        objDomGroup.Close()
        dirSearcher = Nothing
        objDomGroup = Nothing



        modifDonneesAD()

        ' UPLOAD DES FICHIERS PAR FTP
        persoFTP.UploadFile("c:\temp\eq.txt", "/" & repd & "/eq.txt")
        persoFTP.UploadFile("c:\temp\listep.txt", "/" & repd & "/listep.txt")


        Sleep(5000)

        Try
            Kill("c:\temp\listepers.txt")
        Catch
            Journal("ECHEC : suppression du fichier temporaire listepers.txt", True)
        End Try
        Try
            Kill("c:\temp\listep.txt")
        Catch
            Journal("ECHEC : suppression du fichier temporaire listep.txt", True)
        End Try
        Try
            Kill("c:\temp\eq.txt")
        Catch
            Journal("ECHEC : suppression du fichier temporaire eq.txt", True)
        End Try
        Try
            Kill("c:\temp\listep1.txt")
        Catch
            Journal("ECHEC : suppression du fichier temporaire listep1.txt", True)
        End Try

        If controlSendMail = True Then
            SendEmail("userprog@igbmc.fr", "steph@igbmc.fr", "ModifAuto.NET : Rapport d'erreur", journalECHECMail)
        End If

        Journal("Fin de traitement" & vbCrLf)

    End Sub
    Shared Sub modifDonneesAD()
        'COMPARAISON DU PERSONNEL ENTRE HIER ET AUJOURDH'HUI ET CREATION DU FICHIER DE MODIFICATIONS


        Dim Ldap As DirectoryEntry = New DirectoryEntry("LDAP://DC=igbmc,DC=u-strasbg,DC=fr")

        Dim ancienEQ As String = ""

        Dim test As String = ""
        Dim CNChef As String


        Dim objuser As DirectoryEntry
        For n = 0 To UBound(tabPerso1, 2)

            Try
                CNChef = "?"
                Dim searcher As DirectorySearcher = New DirectorySearcher(Ldap)
                searcher.Filter = "(&(objectClass=user) (SAMAccountName=" & tabPerso1(2, n) & "))"
                Dim result As SearchResult = searcher.FindOne()


                objuser = result.GetDirectoryEntry()

                result = Nothing
                searcher = Nothing

                'recuperation de l'ancienne equipe comptable
                If objuser.Properties("DepartmentNumber").Value <> "" Then
                    ancienEQ = objuser.Properties("DepartmentNumber").Value
                End If
                'On Error Resume Next


                'Gestion des Thumbnails
                Thumbn.ComparePhoto(TransformeSAMACCOUNTenCN(tabPerso1(2, n)), tabPerso1(10, n), objuser)

                'Gestion des données basiques
                If ((objuser.Properties("SN").Value <> tabPerso1(0, n)) Or (objuser.Properties("givenName").Value <> tabPerso1(1, n)) Or (objuser.Properties("mail").Value <> tabPerso1(2, n) & "@igbmc.fr") Or (objuser.Properties("physicalDeliveryOfficeName").Value <> tabPerso1(6, n)) Or (objuser.Properties("TelephoneNumber").Value <> tabPerso1(7, n))) Then
                    objuser.Properties("SN").Value = tabPerso1(0, n)
                    objuser.Properties("givenName").Value = tabPerso1(1, n)
                    objuser.Properties("mail").Value = tabPerso1(2, n) & "@igbmc.fr"
                    objuser.Properties("physicalDeliveryOfficeName").Value = tabPerso1(6, n)
                    objuser.Properties("TelephoneNumber").Value = tabPerso1(7, n)
                    objuser.CommitChanges()
                End If

                'Données UNIX
                Try
                    Dim donneesUNIXAd As String = objuser.Properties("uidnumber").Value & "," & objuser.Properties("gidnumber").Value & "," & objuser.Properties("unixHomeDirectory").Value
                    Dim donnesUNIXLdap As String = DonneesUnix(tabPerso1(2, n), tabPerso1(8, n))
                    If donneesUNIXAd <> donnesUNIXLdap Then
                        Dim tabDonneesUnix As String() = Split(donnesUNIXLdap, ",")
                        If objuser.Properties("uidnumber").Value <> tabDonneesUnix(0) Then
                            objuser.Properties("uidnumber").Value = tabDonneesUnix(0)
                        End If
                        If objuser.Properties("gidnumber").Value <> tabDonneesUnix(1) Then
                            objuser.Properties("gidnumber").Value = tabDonneesUnix(1)
                        End If
                        If objuser.Properties("unixHomeDirectory").Value <> tabDonneesUnix(2) Then
                            objuser.Properties("unixHomeDirectory").Value = tabDonneesUnix(2)
                        End If
                        objuser.CommitChanges()
                    End If
                Catch
                    Journal("ECHEC : Modification des attributs Unix de l'utilisateur : " & tabPerso1(2, n), True)
                End Try


                'Chef d'équipe
                If tabPerso1(9, n) <> "?" Then
                    CNChef = TransformeSAMACCOUNTenCN(tabPerso1(9, n))
                End If
                If CNChef <> "?" Then

                    If objuser.Properties("Manager").Value <> CNChef Then
                        objuser.Properties("Manager").Value = CNChef
                        objuser.CommitChanges()
                    End If
                    'On Error GoTo 0
                End If
            Catch
                Journal("ECHEC : Controle de modification de l'utilisateur : " & tabPerso1(2, n), True)
            End Try

            'gestion des appartenance aux groupes equipes (grp)
            CompararaisonAjoutRetraitEquipesComptables(tabPerso1(2, n))
            'Correction equipe

            Try
                If (objuser.Properties("Company").Value <> "IGBMC") Or (objuser.Properties("Department").Value <> tabPerso1(4, n)) Or (objuser.Properties("DepartmentNumber").Value <> tabPerso1(3, n)) Then

                    objuser.Properties("Company").Value = "IGBMC"
                    objuser.Properties("Department").Value = tabPerso1(4, n)
                    objuser.Properties("DepartmentNumber").Value = tabPerso1(3, n)
                    objuser.CommitChanges()


                    'ajout et retrait du groupe ADMINISTRATIF en fonction de la nouvelle equipe
                    Dim objGroupe = GetObject("LDAP://CN=G_ADMINISTRATIF_Users,OU=Droits,OU=Groupes,DC=igbmc,DC=u-strasbg,DC=fr")
                    Dim membreGroupADM As Boolean = MembreGroupeAdministratif(objuser)
                    Dim membreEquipeADM As Boolean = MembreEquipeAdministratif(objuser)

                    If membreEquipeADM = True And membreGroupADM = False Then
                        objGroupe.Add(objuser.Path)
                    End If
                    If membreEquipeADM = False And membreGroupADM = True Then
                        objGroupe.Remove(objuser.Path)
                    End If
                    objGroupe = Nothing
                End If
            Catch
                Journal("ECHEC : Modification : Changer l'equipe de l'utilisateur : " & tabPerso1(2, n), True)
            End Try


            If objuser.Properties("displayName").Value <> tabPerso1(1, n) & " " & tabPerso1(0, n) Then
                objuser.Properties("displayName").Value = tabPerso1(1, n) & " " & tabPerso1(0, n)
                objuser.CommitChanges()
            End If


            If objuser.Properties("cn").Value <> objuser.Properties("displayName").Value Then
                Try
                    Dim objDom As ActiveDs.IADsContainer = GetObject(objuser.Parent.Path)
                    objDom.MoveHere(objuser.Path, "cn=" & objuser.Properties("displayName").Value)
                    objDom = Nothing
                Catch
                    Journal("ECHEC : Modification : Renomer l'objet utilisateur : " & tabPerso1(2, n), True)
                End Try

                Try
                    'Modification des alias de mails
                    Dim currentAddresses = objuser.Properties("proxyAddresses").Value
                    Dim adress As New List(Of String)
                    For Each value In currentAddresses
                        adress.Add(value)
                    Next
                    adress.Add("smtp:" & Replace(tabPerso1(1, n), " ", "-") & "." & Replace(tabPerso1(0, n), " ", "-") & "@igbmc.fr")
                    adress.Add("smtp:" & Replace(tabPerso1(1, n), " ", "-") & "." & Replace(tabPerso1(0, n), " ", "-") & "@igbmc.u-strasbg.fr")
                    objuser.Properties("proxyAddresses").Value = adress.ToArray()
                    objuser.CommitChanges()
                    currentAddresses = Nothing
                    adress.Clear()
                    adress = Nothing
                Catch
                    Journal("ECHEC : Modification : Ajout d'Alias : " & tabPerso1(2, n), True)
                End Try

            End If


            Shell("PASCmd serv-impr ur " & tabPerso1(2, n) & " modify """ & objuser.Properties("givenName").Value & " " & objuser.Properties("SN").Value & """ """ & objuser.Properties("Department").Value & """ """ & objuser.Properties("mail").Value & """ 10", AppWinStyle.Hide)

            objuser.Close()
            objuser = Nothing

        Next n

        Ldap.Close()

        Desactivecompte()
        Reactivecompte()
    End Sub

    Shared Sub Desactivecompte()

        Dim OUdest = "LDAP://OU=Comptes Désactivés,OU=Utilisateurs,DC=igbmc,DC=u-strasbg,DC=fr"
        Dim OUsource As DirectoryEntry = New DirectoryEntry("LDAP://OU=Utilisateurs,DC=igbmc,DC=u-strasbg,DC=fr")
        Dim GroupPath As New DirectoryEntry("LDAP://CN=G_Domain_DisableOpenSession,OU=REFUS,OU=Groupes,DC=igbmc,DC=u-strasbg,DC=fr")

        Dim searcher As DirectorySearcher = New DirectorySearcher(OUsource)
        searcher.Filter = "(&(objectClass=user))"
        ' pour la recherche non recursive(SearchScope.OneLevel)
        searcher.SearchScope = SearchScope.OneLevel
        For Each user As SearchResult In searcher.FindAll()
            Dim ctrl As Boolean = False
            Dim DirEntry = user.GetDirectoryEntry

            Dim login As String = DirEntry.Properties("SAMAccountName").Value()
            For i = 0 To UBound(tabPerso1, 2)
                If login = tabPerso1(2, i) Then
                    ctrl = True
                    Exit For
                End If
            Next i

            If ctrl = False Then
                Try
                    GroupPath.Invoke("Add", New Object() {user.Path.ToString})
                Catch ex As Exception
                    Journal("ECHEC : désactivation du compte(ajout G_Domain_DisableOpenSession) : " & DirEntry.Name, True)
                End Try
                Try
                    DirEntry.Properties("description").Value = "Désactivé le: " & Strings.Left(CStr(Now), 10)
                    DirEntry.Properties("info").Value += "Désactivé le: " & Strings.Left(CStr(Now), 10) & " (ModifAuto)" & vbCrLf
                    DirEntry.CommitChanges()
                Catch ex As Exception
                    Journal("ECHEC : désactivation du compte(propriétés) : " & DirEntry.Name, True)
                End Try
                Try
                    DirEntry.MoveTo(New DirectoryEntry(OUdest))
                Catch ex As Exception
                    Journal("ECHEC : désactivation du compte (deplacement) : " & DirEntry.Name, True)
                End Try

            End If

        Next
        FileClose(2)
        GroupPath.Close()
        GroupPath = Nothing
        OUsource.Close()
        OUsource = Nothing
    End Sub

    Shared Sub Reactivecompte()

        Dim OUdest = "LDAP://OU=Utilisateurs,DC=igbmc,DC=u-strasbg,DC=fr"
        Dim Ldap As DirectoryEntry = New DirectoryEntry("LDAP://OU=Comptes Désactivés,OU=Utilisateurs,DC=igbmc,DC=u-strasbg,DC=fr")
        Dim GroupPath As New DirectoryEntry("LDAP://CN=G_Domain_DisableOpenSession,OU=REFUS,OU=Groupes,DC=igbmc,DC=u-strasbg,DC=fr")

        Dim searcher As DirectorySearcher = New DirectorySearcher(Ldap)
        searcher.Filter = "(&(objectClass=user))"
        ' pour la recherche non recursive(SearchScope.OneLevel)
        searcher.SearchScope = SearchScope.OneLevel
        For Each user As SearchResult In searcher.FindAll()
            Dim ctrl As Boolean = False
            Dim DirEntry = user.GetDirectoryEntry

            Dim login As String = DirEntry.Properties("SAMAccountName").Value()
            For i = 0 To UBound(tabPerso1, 2)
                If login = tabPerso1(2, i) Then
                    Try
                        GroupPath.Invoke("Remove", New Object() {user.Path.ToString})
                    Catch ex As Exception
                    End Try
                    Try
                        DirEntry.Properties("description").Value = " "
                        DirEntry.Properties("info").Value += "Réactivé le: " & Strings.Left(CStr(Now), 10) & " (ModifAuto)" & vbCrLf
                        DirEntry.CommitChanges()
                    Catch ex As Exception
                    End Try
                    Try
                        DirEntry.MoveTo(New DirectoryEntry(OUdest))
                        Exit For
                    Catch ex As Exception
                        Exit For
                    End Try
                End If
            Next i

        Next
        FileClose(2)
        GroupPath.Close()
        GroupPath = Nothing
        Ldap.Close()
        Ldap = Nothing
    End Sub
    Shared Function TransformeSAMACCOUNTenCN(ByVal login As String) As String
        Dim Ldap As DirectoryEntry = New DirectoryEntry("LDAP://DC=igbmc,DC=u-strasbg,DC=fr")
        Dim searcher As DirectorySearcher = New DirectorySearcher(Ldap)
        searcher.Filter = "(&(objectClass=user) (SAMAccountName=" & login & "))"
        Dim result As SearchResult = searcher.FindOne()
        If result Is Nothing Then
            Return ""
        Else
            Dim pathCN As String = Replace(result.Path, "LDAP://", "")
            Return pathCN
        End If

    End Function
    Shared Function Check_If_Member_Of_AD_Group(ByVal username As String) As String()
        Dim appartientA As String()
        Dim j As Integer = 0
        Dim Entry As New System.DirectoryServices.DirectoryEntry("LDAP://DC=igbmc,DC=u-strasbg,DC=fr")
        Dim Searcher As New System.DirectoryServices.DirectorySearcher(Entry)
        Searcher.SearchScope = DirectoryServices.SearchScope.Subtree
        Searcher.Filter = "(&(objectcategory=user)(SAMAccountName=" & username & "))"
        Dim res As SearchResult = Searcher.FindOne
        For i = 0 To res.Properties("memberOf").Count() - 1
            Dim temp As String = Replace(res.Properties("memberOf")(i).ToString, ",OU=Equipes,DC=igbmc,DC=u-strasbg,DC=fr", "")
            temp = Replace(temp, "CN=", "")
            If Strings.Right(temp, 4) = " grp" Then
                ReDim Preserve appartientA(j)
                appartientA(j) = temp
                j += 1
            End If
        Next
        Return appartientA
        Entry.Close()

    End Function
    Shared Function AppartientGroup(ByVal username As String, ByVal equipeGRP As String) As Boolean
        Dim j As Integer = 0
        Dim Entry As New System.DirectoryServices.DirectoryEntry("LDAP://DC=igbmc,DC=u-strasbg,DC=fr")
        Dim Searcher As New System.DirectoryServices.DirectorySearcher(Entry)
        Searcher.SearchScope = DirectoryServices.SearchScope.Subtree
        Searcher.Filter = "(&(objectcategory=user)(SAMAccountName=" & username & "))"
        Dim res As SearchResult = Searcher.FindOne
        For i = 0 To res.Properties("memberOf").Count() - 1
            Dim sProp As String = res.Properties("MemberOf")(i)
            Dim temp As String = sProp.Substring(3, sProp.IndexOf(",") - 3)
            If temp = UCase(equipeGRP) & " grp" Then
                Return True
                Exit Function
            End If
        Next
        Return False
        Entry.Close()
    End Function
    Shared Function EquipeComptableUser(ByVal login As String) As String()
        Dim srJ As StreamReader = New StreamReader("c:\temp\listepers.txt", System.Text.Encoding.Default)
        Dim ligneFichier As String
        Dim equipeUser() As String
        Dim j As Integer = 0
        Do
            ligneFichier = srJ.ReadLine

            If ligneFichier Is Nothing Then
                Exit Do
            Else
                Dim temp As String() = Split(ligneFichier, ",")
                If temp(2) = login Then
                    ReDim Preserve equipeUser(j)
                    equipeUser(j) = temp(3) & " grp"
                    j += 1
                End If
            End If
        Loop
        srJ.Close()

        Return equipeUser
    End Function
    Public Shared Sub CompararaisonAjoutRetraitEquipesComptables(ByVal login As String)
        Dim EquipeUserAD As String() = Check_If_Member_Of_AD_Group(login)
        Dim EquipeUserFichier As String() = EquipeComptableUser(login)
        If Not EquipeUserAD Is Nothing And Not EquipeUserFichier Is Nothing Then
            For i = 0 To UBound(EquipeUserAD)
                For j = 0 To UBound(EquipeUserFichier)
                    If EquipeUserFichier(j) <> "" Then
                        If EquipeUserAD(i) = EquipeUserFichier(j) Then
                            EquipeUserAD(i) = ""
                            EquipeUserFichier(j) = ""
                        End If
                    End If
                Next
            Next
        End If

        Dim Ldap As DirectoryEntry = New DirectoryEntry("LDAP://DC=igbmc,DC=u-strasbg,DC=fr")
        Dim searcher As DirectorySearcher = New DirectorySearcher(Ldap)
        searcher.Filter = "(&(objectClass=user) (SAMAccountName=" & login & "))"
        Dim result1 As SearchResult = searcher.FindOne()

        If Not EquipeUserFichier Is Nothing Then
            For j = 0 To UBound(EquipeUserFichier)
                If EquipeUserFichier(j) <> "" Then
                    Dim GroupPath As New DirectoryEntry("LDAP://CN=" & EquipeUserFichier(j) & ",OU=Equipes,DC=igbmc,DC=u-strasbg,DC=fr")
                    GroupPath.Invoke("Add", New Object() {result1.Path.ToString})
                    GroupPath = Nothing
                End If
            Next j
        End If

        If Not EquipeUserAD Is Nothing Then
            For i = 0 To UBound(EquipeUserAD)
                If EquipeUserAD(i) <> "" Then
                    Dim GroupPath As New DirectoryEntry("LDAP://CN=" & EquipeUserAD(i) & ",OU=Equipes,DC=igbmc,DC=u-strasbg,DC=fr")
                    GroupPath.Invoke("Remove", New Object() {result1.Path.ToString})
                    GroupPath = Nothing
                End If
            Next
        End If

        searcher = Nothing
        Ldap.Close()
    End Sub
    Shared Function MembreEquipeAdministratif(ByVal user As DirectoryEntry) As Boolean

        Try
            Dim control As Boolean = False
            For i As Integer = 0 To user.Properties("MemberOf").Count - 1
                'Récupère la chaine LDAP.
                Dim sProp As String = user.Properties("MemberOf")(i)
                Dim nomEquipe As String = sProp.Substring(3, sProp.IndexOf(",") - 3)
                If nomEquipe = "achat_eq" Or nomEquipe = "adm-gen_eq" Or nomEquipe = "adm-gie_eq" Or nomEquipe = "adm-scien_eq" Or nomEquipe = "bios_eq" Or nomEquipe = "communication_eq" Or nomEquipe = "finance_eq" Or nomEquipe = "info-ics_eq" Or nomEquipe = "info-igbmc_eq" Or nomEquipe = "infra_eq" Or nomEquipe = "rh_eq" Or nomEquipe = "secretariat_eq" Then
                    Return True
                    Exit Function
                End If
            Next
        Catch ex As Exception

        End Try

        Return False

    End Function
    Shared Function MembreGroupeAdministratif(ByVal user As DirectoryEntry) As Boolean

        Try
            Dim CNuser As String = Replace(user.Path, "LDAP://", "")
            Dim groupAdministratif As DirectoryEntry = New DirectoryEntry("LDAP://CN=G_ADMINISTRATIF_Users,OU=Droits,OU=Groupes,DC=igbmc,DC=u-strasbg,DC=fr")
            Dim control As Boolean = False
            For i As Integer = 0 To groupAdministratif.Properties("Member").Count - 1
                'Récupère la chaine LDAP.
                Dim membre As String = groupAdministratif.Properties("Member")(i)
                If CNuser = membre Then
                    Return True
                    Exit Function
                End If
            Next
        Catch ex As Exception

        End Try

        Return False

    End Function
    Shared Sub Journal(ByVal erreur As String, Optional ByVal envoyerMail As Boolean = False)
        Dim fichierLog = "c:\temp\LogModifAuto.log"

        If envoyerMail = True Then
            controlSendMail = True
        End If

        If Not File.Exists(fichierLog) Then
            IO.File.Create(fichierLog)
        End If
        File.AppendAllText(fichierLog, Now & " : " & erreur & vbCrLf)
        journalECHECMail = journalECHECMail & vbCrLf & Now & " : " & erreur

    End Sub
    Shared Function DonneesUnix(ByVal login As String, ByVal equipe As String) As String

        Dim LdapU As DirectoryEntry = New DirectoryEntry("LDAP://ldap-igbmc.u-strasbg.fr:389/ou=People,dc=igbmc,dc=fr", "", "", AuthenticationTypes.Anonymous)
        Dim ResultFields() As String = {"uidnumber", "homedirectory"}
        Dim searcherLdapU As DirectorySearcher = New DirectorySearcher(LdapU)
        searcherLdapU.Filter = "uid=" & login
        searcherLdapU.PropertiesToLoad.AddRange(ResultFields)
        Dim resultLdapU As SearchResult = searcherLdapU.FindOne()

        Dim EquipeInfo As DirectoryEntry = New DirectoryEntry("LDAP://cn=" & equipe & "_eq,OU=Equipes,OU=EMC Celerra,DC=igbmc,DC=u-strasbg,DC=fr")
        Dim unixGID As String = EquipeInfo.Properties("gidnumber").Value
        EquipeInfo.Close()
        EquipeInfo = Nothing

        Return resultLdapU.Properties("uidnumber")(0) & "," & unixGID & "," & resultLdapU.Properties("homedirectory")(0)
        searcherLdapU = Nothing
        LdapU.Close()
        LdapU = Nothing

    End Function

    Shared Sub SendEmail(ByVal sender As String, _
      ByVal recipient As String, ByVal subject As String, _
      ByVal body As String, Optional ByVal attachmentString As String = "")

        Try

            Dim fromAddress As New MailAddress(sender)
            Dim toAddress As New MailAddress(recipient)
            Dim message As New MailMessage(fromAddress, toAddress)

            Dim mailSender As SmtpClient = New SmtpClient("serv-hub.igbmc.u-strasbg.fr", 25)
            With mailSender

                .Credentials = New Net.NetworkCredential("userprog", "FV,k,~?qa3 8ESYjYF9%", "igbmc")
                '.UseDefaultCredentials = false
                .EnableSsl = False

            End With

            message.Bcc.Add(fromAddress)
            message.Subject = subject
            message.IsBodyHtml = False
            message.Body = body

            If Not attachmentString = "" Then
                Dim msgAttach As New Attachment(attachmentString)
                message.Attachments.Add(msgAttach)
            End If

            mailSender.Send(message)

        Catch
            Journal("ECHEC : echec de l'envoi de mail", True)
        End Try
    End Sub




End Class




